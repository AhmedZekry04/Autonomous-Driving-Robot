#!/bin/bash

# 当期版本
export APP="1.0"
export VERSION="|V1.0.2|App$APP|2024-10-22|"

# 雷达类型：A1/A2/C1/G4/S2L/LD14P
export LIDAR_TYPE=A1

# 深度摄像头类型：AstraProPlus
export DEPTH_CAMERA_TYPE=AstraProPlus

# 机器类型：JetAcker
export MACHINE_TYPE=JetAcker

# 主从机设置：robot_xxx
export ROBOT_HOST=robot_1
export ROBOT_MASTER=robot_1

# 语言设置，主要涉及语音部分：Chinese/English
export ASR_LANGUAGE=English

echo -e "\033[32m----------------------------------------------
当前环境是ROS1|The current environment is ROS1
----------------------------------------------\033[0m"
echo -e "LIDAR:   \033[32m$LIDAR_TYPE\033[0m"
echo -e "CAMERA:  \033[32m$DEPTH_CAMERA_TYPE\033[0m"
echo -e "MACHINE: \033[32m$MACHINE_TYPE\033[0m"
echo -e "HOST:    \033[32m$ROBOT_HOST\033[0m"
echo -e "MASTER:  \033[32m$ROBOT_MASTER\033[0m"
echo -e "VERSION: \033[32m$VERSION\033[0m"
